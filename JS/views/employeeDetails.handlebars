<style>
.morning {
  background-color: yellow;
}
</style>

<h1>Employee Details</h1>

<p>
  Name: {{employeeName}} <br>
  Phone: {{phone}}
</p>

<img src="{{photo}}" width="150">

<p>
  <a href="/edit/{{_id}}">Edit Details</a>
</p>

<h2>Shifts</h2>

{{#if items.length}}
  <table>
    <tr>
      <th>Date</th>
      <th>Start Time</th>
      <th>End Time</th>
    </tr>

    {{#each items}}
      <tr>
        <td>{{date}}</td>
        <td class="{{#if isMorning}}morning{{/if}}">
          {{startTime}}
        </td>
        <td>{{endTime}}</td>
      </tr>
    {{/each}}
  </table>
{{else}}
  <p>No shifts assigned.</p>
{{/if}}