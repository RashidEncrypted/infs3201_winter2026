<style>
  .morning {
    background-color: yellow;
  }

  p{
    font-size: 18px;
  }

  .edit-link {
    display: inline-block;
    text-decoration: none;
    color: white;
    background-color: #0077cc;
    padding: 8px 14px;
    border-radius: 6px;
  }

  table {
    width: 20%;
    border-collapse: collapse;
    margin-top: 10px;
  }

  th, td {
    border: 1px solid #d6d6d6;
    padding: 10px;
    text-align: left;
  }

  th {
    background-color: #f2f2f2;
  }
</style>

<h1>Employee Details</h1>

<img src="{{photo}}" width="150">

<p>
  Name: {{employeeName}} <br>
  Phone: {{phone}}
</p>

<p>
  <a class="edit-link" href="/edit/{{_id}}">Edit Details</a>
</p>

{{#if message}}
  <p>{{message}}</p>
{{/if}}

<h2>Upload Document</h2>

<form method="POST" action="/employee/{{_id}}/upload" enctype="multipart/form-data">
  <p>
    <input type="file" name="document" accept=".pdf">
  </p>

  <button type="submit">Upload PDF</button>
</form>

<h2>Documents</h2>

{{#if documents.length}}
  <ul>
    {{#each documents}}
      <li>{{originalName}}</li>
    {{/each}}
  </ul>
{{else}}
  <p>No documents uploaded.</p>
{{/if}}

<h2>Shifts</h2>

{{#if items.length}}
  <table>
    <tr>
      <th>Date</th>
      <th>Start Time</th>
      <th>End Time</th>
    </tr>

    {{#each items}}
      <tr>
        <td>{{date}}</td>
        <td class="{{#if isMorning}}morning{{/if}}">
          {{startTime}}
        </td>
        <td>{{endTime}}</td>
      </tr>
    {{/each}}
  </table>
{{else}}
  <p>No shifts assigned.</p>
{{/if}}